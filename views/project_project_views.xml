<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_legal_dms_structure" model="ir.ui.view">
        <field name="name">project.project.form.legal.dms.structure</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_title')]//h1" position="before">
                <field name="dms_directory_id" invisible="1" />
                <field name="dms_archived_directory_id" invisible="1" />
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_archive_legal_dms"
                    type="object"
                    string="Archive DMS"
                    class="oe_stat_button"
                    icon="fa-archive"
                    groups="legal_dms_structure.group_legal_dms_admin"
                    invisible="not dms_directory_id"
                />
                <button
                    name="action_unarchive_legal_dms"
                    type="object"
                    string="Restore DMS"
                    class="oe_stat_button"
                    icon="fa-history"
                    groups="legal_dms_structure.group_legal_dms_admin"
                    invisible="not dms_archived_directory_id"
                />
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="legal_dms" string="Legal DMS" invisible="not id">
                    <group>
                        <group>
                            <field name="dms_directory_id" readonly="1" />
                            <field name="dms_archived_directory_id" readonly="1" />
                        </group>
                    </group>
                    <field name="dms_directory_ids" mode="dms_list" />
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_project_form_legal_dms_smart_buttons" model="ir.ui.view">
        <field name="name">project.project.form.legal.dms.smart.buttons</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project" />
        <field name="priority">90</field>
        <field name="key">legal_dms_structure.smart_buttons_project</field>
        <field name="arch" type="xml">
            <data />
        </field>
    </record>
</odoo>
