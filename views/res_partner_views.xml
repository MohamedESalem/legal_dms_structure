<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_legal_dms_structure" model="ir.ui.view">
        <field name="name">res.partner.form.legal.dms.structure</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet[1]" position="before">
                <header />
            </xpath>

            <xpath expr="//field[@name='company_type']" position="after">
                <field name="dms_directory_id" invisible="1" />
                <field name="dms_archived_directory_id" invisible="1" />
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_archive_legal_dms"
                    type="object"
                    string="Archive DMS"
                    class="oe_stat_button"
                    icon="fa-archive"
                    groups="legal_dms_structure.group_legal_dms_admin"
                    invisible="not dms_directory_id"
                />
                <button
                    name="action_unarchive_legal_dms"
                    type="object"
                    string="Restore DMS"
                    class="oe_stat_button"
                    icon="fa-history"
                    groups="legal_dms_structure.group_legal_dms_admin"
                    invisible="not dms_archived_directory_id"
                />
            </xpath>
        </field>
    </record>

    <record id="view_partner_form_legal_dms_smart_buttons" model="ir.ui.view">
        <field name="name">res.partner.form.legal.dms.smart.buttons</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="legal_dms_structure.view_partner_form_legal_dms_structure" />
        <field name="priority">90</field>
        <field name="key">legal_dms_structure.smart_buttons_partner</field>
        <field name="arch" type="xml">
            <data />
        </field>
    </record>
</odoo>
